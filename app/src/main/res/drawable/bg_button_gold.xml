<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="180"
                android:endColor="#A07820"
                android:startColor="#B8952A"
                android:type="linear" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="180"
                android:centerColor="#D4AF37"
                android:endColor="#B8952A"
                android:startColor="#E8CC55"
                android:type="linear" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#F0DA6A" />
        </shape>
    </item>
</selector>
