<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1A0E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ===== JUDUL HALAMAN ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="3dp"
                android:layout_height="28dp"
                android:background="#D4AF37" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="serif"
                android:letterSpacing="0.05"
                android:text="TIKET RESERVASI"
                android:textColor="#D4AF37"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ===== TICKET CARD ===== -->
        <LinearLayout
            android:id="@+id/boxTicket"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_form_card"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <!-- ─── Header Tiket ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#0B1509"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BILLIARD VIP"
                        android:textColor="#9A832A"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:id="@+id/tvTicketId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID #RES-20250101-001"
                        android:textColor="#6B6040"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Badge Status -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_gold"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONFIRMED"
                        android:textColor="#1A1A0A"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />
                </LinearLayout>
            </LinearLayout>

            <!-- ─── Isi Tiket ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Nama Reservasi -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NAMA RESERVASI"
                    android:textColor="#9A832A"
                    android:textSize="9sp"
                    android:letterSpacing="0.10"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#D4AF37"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_marginBottom="14dp" />

                <!-- Tanggal & Waktu -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TANGGAL CHECK-IN"
                            android:textColor="#9A832A"
                            android:textSize="9sp"
                            android:letterSpacing="0.10"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#E8D48A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JAM CHECK-IN"
                            android:textColor="#9A832A"
                            android:textSize="9sp"
                            android:letterSpacing="0.10"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#E8D48A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Tipe Meja -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIPE MEJA"
                    android:textColor="#9A832A"
                    android:textSize="9sp"
                    android:letterSpacing="0.10"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/tvRoomType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reguler"
                        android:textColor="#E8D48A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:layout_marginEnd="8dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_gold"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MEJA"
                            android:textColor="#1A1A0A"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Jumlah Meja & Jam Bermain -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JUMLAH MEJA"
                            android:textColor="#9A832A"
                            android:textSize="9sp"
                            android:letterSpacing="0.10"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvQuantity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#E8D48A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JAM BERMAIN"
                            android:textColor="#9A832A"
                            android:textSize="9sp"
                            android:letterSpacing="0.10"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvHours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#E8D48A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ─── Tear Line ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Setengah lingkaran kiri -->
                <View
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@drawable/circle_cutout"
                    android:layout_marginStart="-8dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@drawable/dashed_line_gold" />

                <!-- Setengah lingkaran kanan -->
                <View
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@drawable/circle_cutout"
                    android:layout_marginEnd="-8dp" />
            </LinearLayout>

            <!-- ─── Total Harga ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TOTAL HARGA"
                    android:textColor="#9A832A"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tvTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 0"
                    android:textColor="#D4AF37"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvBreakdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="14dp"
                android:text="Rp 0 × jam"
                android:textColor="#6B6040"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- ===== BARCODE SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_form_card"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIKET BARCODE"
                android:textColor="#9A832A"
                android:textSize="9sp"
                android:letterSpacing="0.10"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginBottom="12dp" />

            <ImageView
                android:id="@+id/imgBarcode"
                android:layout_width="260dp"
                android:layout_height="85dp"
                android:src="@drawable/barcode"
                android:layout_gravity="center"
                app:tint="#D4AF37" />

            <TextView
                android:id="@+id/tvBarcodeNum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="6dp"
                android:text="RES-20250101-001"
                android:textColor="#6B6040"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15" />
        </LinearLayout>

        <!-- ===== INFO LINK ===== -->
        <TextView
            android:id="@+id/txtInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:text="Lihat detail informasi →"
            android:textColor="#9A832A"
            android:textSize="11sp"
            android:letterSpacing="0.06"
            android:textStyle="bold" />

        <!-- Bola dekorasi -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View android:layout_width="10dp" android:layout_height="10dp"
                android:layout_marginEnd="8dp" android:background="@drawable/ball_red" />
            <View android:layout_width="10dp" android:layout_height="10dp"
                android:layout_marginEnd="8dp" android:background="@drawable/ball_yellow" />
            <View android:layout_width="10dp" android:layout_height="10dp"
                android:layout_marginEnd="8dp" android:background="@drawable/ball_black" />
            <View android:layout_width="10dp" android:layout_height="10dp"
                android:layout_marginEnd="8dp" android:background="@drawable/ball_yellow" />
            <View android:layout_width="10dp" android:layout_height="10dp"
                android:background="@drawable/ball_red" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="90dp" />

    </LinearLayout>
</ScrollView>