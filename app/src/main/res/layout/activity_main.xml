<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1A0E">

    <!-- ===== GARIS ATAS DEKORASI ===== -->
    <View
        android:id="@+id/lineTop"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="#D4AF37"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== LOGO BERLAPIS (seperti bola biliar) ===== -->
    <FrameLayout
        android:id="@+id/logoFrame"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/lineTop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Ring terluar -->
        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/bg_ball_outer_ring" />

        <!-- Ring gold -->
        <View
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_ball_gold_ring" />

        <!-- Lingkaran dalam -->
        <View
            android:layout_width="118dp"
            android:layout_height="118dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_ball_inner" />

        <!-- Logo rack -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:src="@drawable/rack"
            app:tint="#D4AF37" />
    </FrameLayout>

    <!-- ===== NAMA APP ===== -->
    <TextView
        android:id="@+id/brand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="serif"
        android:letterSpacing="0.15"
        android:text="GOLDEN BREAK"
        android:textColor="#D4AF37"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/logoFrame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/brandSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:letterSpacing="0.25"
        android:text="BILLIARD CLUB"
        android:textColor="#6B6040"
        android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/brand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== ORNAMEN DIAMOND ===== -->
    <LinearLayout
        android:id="@+id/ornamen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/brandSub"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="80dp"
            android:layout_height="1dp"
            android:background="@drawable/divider_gold_fade_right" />

        <View
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_diamond_gold" />

        <View
            android:layout_width="80dp"
            android:layout_height="1dp"
            android:background="@drawable/divider_gold_fade_left" />
    </LinearLayout>

    <!-- ===== TAGLINE UTAMA ===== -->
    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:fontFamily="serif"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:text="Where Great Shots\nMeet Great Taste"
        android:textColor="#E8D48A"
        android:textSize="22sp"
        android:textStyle="italic"
        app:layout_constraintTop_toBottomOf="@id/ornamen"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== SUBTITLE KECIL ===== -->
    <TextView
        android:id="@+id/small_sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:letterSpacing="0.08"
        android:text="Café &amp; Resto  ·  Lounge  ·  Pool &amp; Events"
        android:textColor="#5A5438"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== DEKORASI BOLA BILIAR ===== -->
    <LinearLayout
        android:id="@+id/ballsRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/small_sub"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View android:layout_width="12dp" android:layout_height="12dp"
            android:layout_marginEnd="10dp" android:background="@drawable/ball_red" />
        <View android:layout_width="12dp" android:layout_height="12dp"
            android:layout_marginEnd="10dp" android:background="@drawable/ball_yellow" />
        <View android:layout_width="14dp" android:layout_height="14dp"
            android:layout_marginEnd="10dp" android:background="@drawable/ball_black" />
        <View android:layout_width="12dp" android:layout_height="12dp"
            android:layout_marginEnd="10dp" android:background="@drawable/ball_yellow" />
        <View android:layout_width="12dp" android:layout_height="12dp"
            android:background="@drawable/ball_red" />
    </LinearLayout>

    <!-- ===== TOMBOL GET STARTED ===== -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="240dp"
        android:layout_height="54dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/bg_button_gold"
        app:backgroundTint="@null"
        android:elevation="6dp"
        android:letterSpacing="0.15"
        android:text="GET STARTED"
        android:textColor="#1A1A0A"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ===== GARIS BAWAH DEKORASI ===== -->
    <View
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="#D4AF37"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>