<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#0E1A0E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== HERO IMAGE ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <ImageView
                android:id="@+id/imgRoom"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                android:src="@drawable/reguler" />

            <!-- Overlay gelap bawah -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_image_overlay" />

            <!-- Badge Regular di atas foto -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="14dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="Regular Room"
                    android:textColor="#D4AF37"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ 4.8"
                        android:textColor="#E8D48A"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="#6B6040" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1k+ Tersewa"
                        android:textColor="#9A832A"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Harga di kanan bawah foto -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_badge_gold"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 40.000"
                    android:textColor="#1A1A0A"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="per jam"
                    android:textColor="#1A1A0A"
                    android:textSize="9sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- ===== KONTEN UTAMA ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ─── Info Card ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_form_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- Lokasi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/location"
                        app:tint="#D4AF37" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LOKASI"
                            android:textColor="#9A832A"
                            android:textSize="9sp"
                            android:letterSpacing="0.10"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Jl. Gajah Mada no.541, Kuta, Bali"
                            android:textColor="#E8D48A"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2A18"
                    android:layout_marginBottom="12dp" />

                <!-- Jam buka -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/clock"
                        app:tint="#D4AF37" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JAM BUKA"
                            android:textColor="#9A832A"
                            android:textSize="9sp"
                            android:letterSpacing="0.10"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvOpenHours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="10.00 – 23.00"
                            android:textColor="#E8D48A"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Status buka -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_status_open"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="5dp"
                            android:background="@drawable/ball_yellow" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Buka"
                            android:textColor="#D4AF37"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ─── Pilih Nomor Meja ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="18dp"
                    android:background="#D4AF37" />

                <TextView
                    android:id="@+id/tvTableNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:letterSpacing="0.08"
                    android:text="PILIH NOMOR MEJA"
                    android:textColor="#D4AF37"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:layout_marginStart="4dp"
                android:text="Ketuk nomor meja yang ingin dipesan"
                android:textColor="#4A4730"
                android:textSize="11sp" />

            <!-- ─── Grid Meja ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_form_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <Button android:id="@+id/btn1" android:text="1"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_table_btn"
                        app:backgroundTint="@null"
                        android:textColor="#D4AF37" android:textSize="14sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btn2" android:text="2"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_table_btn"
                        app:backgroundTint="@null"
                        android:textColor="#D4AF37" android:textSize="14sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btn3" android:text="3"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_table_btn"
                        app:backgroundTint="@null"
                        android:textColor="#D4AF37" android:textSize="14sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btn4" android:text="4"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_table_btn"
                        app:backgroundTint="@null"
                        android:textColor="#D4AF37" android:textSize="14sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btn5" android:text="5"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_table_btn"
                        app:backgroundTint="@null"
                        android:textColor="#D4AF37" android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button android:id="@+id/btn6" android:text="6"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_table_btn"
                        app:backgroundTint="@null"
                        android:textColor="#D4AF37" android:textSize="14sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btn7" android:text="7"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_table_btn"
                        app:backgroundTint="@null"
                        android:textColor="#D4AF37" android:textSize="14sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btn8" android:text="8"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_table_btn"
                        app:backgroundTint="@null"
                        android:textColor="#D4AF37" android:textSize="14sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btn9" android:text="9"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_table_btn"
                        app:backgroundTint="@null"
                        android:textColor="#D4AF37" android:textSize="14sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btn10" android:text="10"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_table_btn"
                        app:backgroundTint="@null"
                        android:textColor="#D4AF37" android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Legenda -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/bg_table_btn" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="16dp"
                        android:text="Tersedia"
                        android:textColor="#4A4730"
                        android:textSize="10sp" />

                    <View
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/bg_table_selected" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="16dp"
                        android:text="Dipilih"
                        android:textColor="#4A4730"
                        android:textSize="10sp" />

                    <View
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/bg_table_booked" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Terpesan"
                        android:textColor="#4A4730"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ─── Tombol Reserve ─── -->
            <Button
                android:id="@+id/btnReserve"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_gold"
                app:backgroundTint="@null"
                android:elevation="4dp"
                android:letterSpacing="0.15"
                android:text="RESERVASI SEKARANG"
                android:textColor="#1A1A0A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Bola dekorasi -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View android:layout_width="10dp" android:layout_height="10dp"
                    android:layout_marginEnd="8dp" android:background="@drawable/ball_red" />
                <View android:layout_width="10dp" android:layout_height="10dp"
                    android:layout_marginEnd="8dp" android:background="@drawable/ball_yellow" />
                <View android:layout_width="10dp" android:layout_height="10dp"
                    android:layout_marginEnd="8dp" android:background="@drawable/ball_black" />
                <View android:layout_width="10dp" android:layout_height="10dp"
                    android:layout_marginEnd="8dp" android:background="@drawable/ball_yellow" />
                <View android:layout_width="10dp" android:layout_height="10dp"
                    android:background="@drawable/ball_red" />
            </LinearLayout>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="90dp" />

    </LinearLayout>
</ScrollView>